{
  "version": 1,
  "description": "Lightweight path→verification map for agent harness. Extend with full dependency graph later.",
  "skipPatterns": [
    ".github/**",
    "**/web/src/generated/**",
    "**/contracts/openapi/.build/**",
    "**/Migrations/**",
    "**/bin/**",
    "**/obj/**",
    "**/e2e/test-results/**",
    "**/e2e/playwright-report/**"
  ],
  "layers": {
    "AGENTS.md": {
      "postEditAction": "test",
      "testCommand": "powershell -NoProfile -ExecutionPolicy Bypass -File evals/run.ps1 -Layer harness"
    },
    ".codex/": {
      "postEditAction": "test",
      "testCommand": "powershell -NoProfile -ExecutionPolicy Bypass -File evals/run.ps1 -Layer harness"
    },
    ".agents/": {
      "postEditAction": "test",
      "testCommand": "powershell -NoProfile -ExecutionPolicy Bypass -File evals/run.ps1 -Layer harness"
    },
    "evals/": {
      "postEditAction": "test",
      "testCommand": "powershell -NoProfile -ExecutionPolicy Bypass -File evals/run.ps1 -Layer harness"
    },
    "scripts/agent/": {
      "postEditAction": "test",
      "testCommand": "powershell -NoProfile -ExecutionPolicy Bypass -File evals/run.ps1 -Layer harness"
    },
    "docs/README.md": {
      "postEditAction": "test",
      "testCommand": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/agent/Test-DocsMemory.ps1"
    },
    "docs/CONSTITUTION.md": {
      "postEditAction": "test",
      "testCommand": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/agent/Test-DocsMemory.ps1"
    },
    "docs/.gitignore": {
      "postEditAction": "test",
      "testCommand": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/agent/Test-DocsMemory.ps1"
    },
    "docs/.obsidian/": {
      "postEditAction": "test",
      "testCommand": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/agent/Test-DocsMemory.ps1"
    },
    "docs/_memory/source/harness-": {
      "postEditAction": "test",
      "testCommand": "powershell -NoProfile -ExecutionPolicy Bypass -File evals/run.ps1 -Layer harness"
    },
    "docs/_memory/": {
      "postEditAction": "test",
      "testCommand": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/agent/Test-DocsMemory.ps1"
    },
    "harness/": {
      "postEditAction": "test",
      "testCommand": "powershell -NoProfile -ExecutionPolicy Bypass -File evals/run.ps1 -Layer harness"
    },
    "scripts/affected-tests.mjs": {
      "postEditAction": "test",
      "testCommand": "powershell -NoProfile -ExecutionPolicy Bypass -File evals/run.ps1 -Layer graph"
    },
    ".graph/": {
      "postEditAction": "test",
      "testCommand": "powershell -NoProfile -ExecutionPolicy Bypass -File evals/run.ps1 -Layer graph"
    },
    "src/Domain/": {
      "postEditAction": "test",
      "testProject": "tests/Domain.UnitTests/EventHub.Domain.UnitTests.csproj",
      "namespaceFromSegment": true
    },
    "src/Application/": {
      "postEditAction": "build",
      "buildProject": "src/Application/EventHub.Application.csproj"
    },
    "src/Infrastructure/": {
      "postEditAction": "build",
      "buildProject": "src/Infrastructure/EventHub.Infrastructure.csproj"
    },
    "src/Api/": {
      "postEditAction": "build",
      "buildProject": "src/Api/EventHub.Api.csproj"
    },
    "src/Contracts/": {
      "postEditAction": "build",
      "buildProject": "src/Contracts/EventHub.Contracts.csproj"
    },
    "tests/Domain.UnitTests/": {
      "postEditAction": "test",
      "testProject": "tests/Domain.UnitTests/EventHub.Domain.UnitTests.csproj"
    },
    "tests/Api.IntegrationTests/": {
      "postEditAction": "test",
      "testProject": "tests/Api.IntegrationTests/EventHub.Api.IntegrationTests.csproj",
      "namespaceFromSegment": true
    },
    "e2e/": {
      "postEditAction": "test",
      "testCommand": "yarn --cwd e2e test --reporter=line"
    }
  }
}
