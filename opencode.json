{
  "$schema": "https://opencode.ai/config.json",
  "shell": "pwsh",
  "default_agent": "build",
  "instructions": [
    "AGENTS.md",
    ".opencode/rules/core.md",
    ".opencode/rules/harness.md",
    ".opencode/rules/reasoning-loop.md",
    ".opencode/rules/context-memory.md"
  ],
  "provider": {
    "mimo": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "MiMo",
      "options": {
        "baseURL": "https://token-plan-cn.xiaomimimo.com/v1",
        "apiKey": "{env:MIMO_API_KEY}"
      },
      "models": {
        "mimo-v2.5-pro": {
          "name": "mimo-v2.5-pro",
          "limit": {
            "context": 1048576,
            "output": 131072
          },
          "modalities": {
            "input": ["text"],
            "output": ["text"]
          }
        },
        "mimo-v2.5": {
          "name": "mimo-v2.5",
          "limit": {
            "context": 1048576,
            "output": 131072
          },
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        }
      }
    }
  },
  "mcp": {
    "aspire": {
      "type": "local",
      "command": ["aspire", "agent", "mcp"],
      "enabled": true
    },
    "postgres": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-postgres",
        "{env:POSTGRES_URI}"
      ],
      "enabled": true
    },
    "neo4j-graphrag": {
      "type": "local",
      "command": [
        "python",
        "-c",
        "from mcp_neo4j_graphrag import main; main()"
      ],
      "enabled": false,
      "environment": {
        "NEO4J_URI": "{env:NEO4J_URI}",
        "NEO4J_USERNAME": "{env:NEO4J_USERNAME}",
        "NEO4J_PASSWORD": "{env:NEO4J_PASSWORD}",
        "NEO4J_DATABASE": "{env:NEO4J_DATABASE}",
        "OPENAI_API_KEY": "{env:OPENAI_API_KEY}",
        "EMBEDDING_MODEL": "{env:EMBEDDING_MODEL}"
      }
    }
  },
  "permission": {
    "skill": {
      "*": "allow"
    }
  }
}
