{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Edit(web/src/generated/*)",
      "Write(web/src/generated/*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|Bash|Agent|Delete",
        "hooks": [
          {
            "type": "command",
            "command": "powershell",
            "args": ["-File", "${CLAUDE_PROJECT_DIR}/.claude/hooks/pre-tool-guard.ps1"],
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(rm *)",
            "command": "powershell",
            "args": ["-File", "${CLAUDE_PROJECT_DIR}/.claude/hooks/before-shell-guard.ps1"],
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "powershell",
            "args": ["-File", "${CLAUDE_PROJECT_DIR}/.claude/hooks/post-edit-verify.ps1"],
            "timeout": 180
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell",
            "args": ["-File", "${CLAUDE_PROJECT_DIR}/.claude/hooks/stop-gate.ps1"],
            "timeout": 300
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell",
            "args": ["-File", "${CLAUDE_PROJECT_DIR}/.claude/hooks/pre-compact-backup.ps1"],
            "timeout": 30
          }
        ]
      }
    ]
  }
}
