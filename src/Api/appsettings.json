{
  "ConnectionStrings": {
    "App": "Host=localhost;Port=5432;Database=app;Username=postgres;Password=postgres",
    "Cache": "localhost:6379",
    "storage": "Endpoint=http://localhost:9000;AccessKey=minioadmin;SecretKey=minioadmin",
    "messaging": "amqp://guest:guest@localhost:5672"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    },
    "MinimumLevel": "Information"
  },
  "AllowedHosts": "*",
  "Session": {
    "CookieName": "EventHub.Session",
    "ExpirationHours": 24
  },
  "Concurrency": {
    "MaxRetryAttempts": 3,
    "BaseDelayMilliseconds": 25
  },
  "Storage": {
    "Bucket": "eventhub"
  },
  "Messaging": {
    "ExchangeName": "eventhub.integration"
  },
  "Realtime": {
    "UseRedisBackplane": false
  }
}
